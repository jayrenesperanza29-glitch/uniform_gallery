# ── Copy this to .env (never commit the real .env) ───────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://uniform_user:uniform_pass@db:5432/uniform_gallery
JWT_SECRET=change-me-in-production

# ── Cloudinary (https://cloudinary.com → Dashboard) ─────────────────────────
# Required on Render so uploaded images survive redeploys.
# Leave blank to use local /static/images/ storage (Docker / dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Point this at your Render (or other) backend URL when deploying
# the frontend separately.  Leave blank for local Docker dev.
VITE_API_URL=

# ── Docker extras ─────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
